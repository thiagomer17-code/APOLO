{
  "name": "apolo",
  "productName": "APOLO",
  "version": "1.0.2",
  "description": "Editor personal de letras con acordes y tablaturas de guitarra, estilo Spotify. Funciona offline, sin cuentas, guardado local.",
  "author": "APOLO <thamerjob7@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "build": "node build/compile.js",
    "start": "node build/compile.js && electron .",
    "pack": "node build/compile.js && electron-builder --dir",
    "dist": "node build/compile.js && electron-builder --win nsis",
    "release": "node build/compile.js && electron-builder --win nsis --publish always"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.apolo.app",
    "productName": "APOLO",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "!src/js/**",
      "!src/vendor/babel.min.js",
      "package.json"
    ],
    "electronLanguages": [
      "en-US",
      "es"
    ],
    "compression": "maximum",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "APOLO"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "thiagomer17-code",
        "repo": "APOLO",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9"
  }
}
